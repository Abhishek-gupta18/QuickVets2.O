# ============================================================
# QuickVet Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# DATABASE: PostgreSQL connection string (REQUIRED)
# Railway gives you this when you create a PostgreSQL service
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quickvet"

# JWT: Secret key for signing authentication tokens (REQUIRED)
# Generate a strong random string (min 32 chars)
JWT_SECRET="your-strong-secret-key-here-change-in-production"

# FRONTEND_URL: Your Vercel frontend URL (for CORS - REQUIRED in production)
# Example: https://quickvet.vercel.app
FRONTEND_URL="http://localhost:5173"

# VITE_API_URL: Backend API URL (set this in Vercel environment variables)
# Leave empty for local dev (same-origin). In production, set to your Render URL.
# Example: https://quickvet-api.onrender.com
VITE_API_URL=""

# GEMINI: Google AI API key (optional, for future AI symptom checker)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE OAUTH: Google Sign-In Client ID (REQUIRED for Google OAuth)
# Create one at: https://console.cloud.google.com/apis/credentials
# Set the authorized JavaScript origins to your frontend URL
# Set the authorized redirect URIs to your frontend URL
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# VITE_GOOGLE_CLIENT_ID: Same as GOOGLE_CLIENT_ID (exposed to frontend via Vite)
# This is used by the frontend to initialize the Google Sign-In button
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# APP: Public URL where this app is hosted (optional)
APP_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────────────────────
# CLOUDINARY: Secure document storage for vet verification files (REQUIRED for
# document uploads to work). Get these from cloudinary.com → Dashboard.
# ──────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ──────────────────────────────────────────────────────────────────────────────
# TEMPORAL: Workflow orchestration for vaccination reminders & AI pipelines
# Install: temporal server start-dev (local development)
# ──────────────────────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE="quickvet-vaccinations"
